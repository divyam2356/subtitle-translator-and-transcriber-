---
import '../styles/global.css';
interface Props { title?: string }
const { title = 'SubtitleAI – Local Video Subtitle Maker & Translator' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content="Generate and translate video subtitles entirely in your browser — no server, no API key." />
    <title>{title}</title>
  </head>
  <body class="bg-bg text-text font-sans min-h-screen">
    <slot />
  </body>
</html>
